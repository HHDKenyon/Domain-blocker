{
  "manifest_version": 3,
  "name": "Domain Blocker",
  "version": "1.0.0",
  "description": "Block or time-limit access to domains on a configurable schedule.",
  "author": "HHDKenyon",

  "permissions": [
    "declarativeNetRequest",
    "storage",
    "alarms",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Domain Blocker"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [{
    "resources": ["blocked/blocked.html"],
    "matches": ["<all_urls>"]
  }],

  "browser_specific_settings": {
    "gecko": {
      "id": "domain-blocker@henrykenyon.com",
      "strict_min_version": "128.0"
    }
  }
}
