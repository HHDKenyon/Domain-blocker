{
  "manifest_version": 2,
  "name": "Domain Blocker",
  "version": "1.0.0",
  "description": "Block or time-limit access to domains on a configurable schedule.",
  "author": "HHDKenyon",
  "license": "GPL-3.0",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "alarms",
    "tabs",
    "windows",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["vendor/browser-polyfill.js", "background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Domain Blocker"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },

  "web_accessible_resources": [
    "blocked/blocked.html"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "domain-blocker@henrykenyon.com",
      "strict_min_version": "57.0"
    }
  }
}
