{
  "manifest_version": 2,
  "name": "Domain Blocker",
  "version": "1.0.0",
  "description": "Block or time-limit access to domains on a configurable schedule.",
  "author": "HHDKenyon",
  "license": "GPL-3.0",

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "alarms",
    "tabs",
    "windows",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    },
    "default_title": "Domain Blocker"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "web_accessible_resources": [
    "blocked/blocked.html"
  ]
}
